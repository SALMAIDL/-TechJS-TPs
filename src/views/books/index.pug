extends ../layout

block content
  .flex.items-center.justify-between.mb-6
    div
      h1.text-2xl.font-bold.text-gray-800 📚 Bibliothèque
      p.text-gray-500.text-sm #{books.length} livre(s) disponible(s)
    a(href="/books/new").bg-indigo-600.hover:bg-indigo-700.text-white.font-medium.px-4.py-2.rounded-lg.transition.text-sm
      | + Ajouter un livre

  if books.length === 0
    .text-center.py-16.text-gray-400
      p.text-5xl.mb-3 📭
      p.text-lg Aucun livre pour le moment.
      a(href="/books/new").text-indigo-500.hover:underline.text-sm Ajouter le premier livre
  else
    .grid.gap-4(class="sm:grid-cols-2 lg:grid-cols-3")
      each book in books
        .bg-white.rounded-xl.shadow-sm.border.border-gray-100.p-5.hover:shadow-md.transition.flex.flex-col.justify-between
          div
            .flex.items-start.justify-between.mb-2
              span.bg-indigo-100.text-indigo-700.text-xs.font-medium.px-2.py-0.5.rounded-full= book.genre || "Général"
              span.text-gray-400.text-xs= book.year || ""
            h2.font-bold.text-gray-800.text-base.mb-1= book.title
            p.text-gray-500.text-sm= book.author
          .flex.items-center.justify-between.mt-4.pt-3.border-t.border-gray-50
            a(href=`/books/${book.id}`).text-indigo-500.text-sm.hover:underline Voir détail
            form(method="POST" action=`/books/${book.id}/delete` onsubmit="return confirm('Supprimer ce livre ?')")
              button.text-red-400.hover:text-red-600.text-sm.transition(type="submit") Supprimer
