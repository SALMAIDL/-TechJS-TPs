extends ../layout

block content
  .max-w-md.mx-auto
    .bg-white.rounded-2xl.shadow-md.p-8
      h1.text-2xl.font-bold.text-gray-800.mb-1 Créer un compte
      p.text-gray-500.text-sm.mb-6 Rejoignez la bibliothèque

      if error
        .bg-red-50.border.border-red-200.text-red-700.rounded-lg.px-4.py-3.mb-5.text-sm
          = error

      form(method="POST" action="/auth/register")
        .mb-4
          label.block.text-sm.font-medium.text-gray-700.mb-1(for="username") Nom d'utilisateur
          input#username.w-full.border.border-gray-300.rounded-lg.px-3.py-2.text-sm.focus:outline-none.focus:ring-2.focus:ring-indigo-400(
            type="text"
            name="username"
            placeholder="votre_pseudo"
            value=values && values.username
            required
            minlength="3"
            autocomplete="username"
          )

        .mb-4
          label.block.text-sm.font-medium.text-gray-700.mb-1(for="email") Email
          input#email.w-full.border.border-gray-300.rounded-lg.px-3.py-2.text-sm.focus:outline-none.focus:ring-2.focus:ring-indigo-400(
            type="email"
            name="email"
            placeholder="vous@email.com"
            value=values && values.email
            required
            autocomplete="email"
          )

        .mb-4
          label.block.text-sm.font-medium.text-gray-700.mb-1(for="password") Mot de passe
          input#password.w-full.border.border-gray-300.rounded-lg.px-3.py-2.text-sm.focus:outline-none.focus:ring-2.focus:ring-indigo-400(
            type="password"
            name="password"
            placeholder="Min. 6 caractères"
            required
            minlength="6"
            autocomplete="new-password"
          )

        .mb-6
          label.block.text-sm.font-medium.text-gray-700.mb-1(for="confirmPassword") Confirmer le mot de passe
          input#confirmPassword.w-full.border.border-gray-300.rounded-lg.px-3.py-2.text-sm.focus:outline-none.focus:ring-2.focus:ring-indigo-400(
            type="password"
            name="confirmPassword"
            placeholder="••••••••"
            required
            autocomplete="new-password"
          )

        button.w-full.bg-indigo-600.hover:bg-indigo-700.text-white.font-semibold.py-2.rounded-lg.transition(type="submit")
          | S'inscrire

      p.text-center.text-sm.text-gray-500.mt-5
        | Déjà un compte ?&nbsp;
        a(href="/auth/login").text-indigo-600.font-medium.hover:underline Se connecter
