extends ../layout

block content
  .max-w-lg.mx-auto
    a(href="/books").text-indigo-500.text-sm.hover:underline.mb-4.inline-block ← Retour à la liste

    .bg-white.rounded-2xl.shadow-md.p-8
      h1.text-2xl.font-bold.text-gray-800.mb-1 Ajouter un livre
      p.text-gray-500.text-sm.mb-6 Renseignez les informations du livre

      if error
        .bg-red-50.border.border-red-200.text-red-700.rounded-lg.px-4.py-3.mb-5.text-sm
          = error

      form(method="POST" action="/books")
        .mb-4
          label.block.text-sm.font-medium.text-gray-700.mb-1(for="title") Titre *
          input#title.w-full.border.border-gray-300.rounded-lg.px-3.py-2.text-sm.focus:outline-none.focus:ring-2.focus:ring-indigo-400(
            type="text"
            name="title"
            placeholder="Ex: Clean Code"
            value=values && values.title
            required
          )

        .mb-4
          label.block.text-sm.font-medium.text-gray-700.mb-1(for="author") Auteur *
          input#author.w-full.border.border-gray-300.rounded-lg.px-3.py-2.text-sm.focus:outline-none.focus:ring-2.focus:ring-indigo-400(
            type="text"
            name="author"
            placeholder="Ex: Robert C. Martin"
            value=values && values.author
            required
          )

        .grid.grid-cols-2.gap-4.mb-6
          div
            label.block.text-sm.font-medium.text-gray-700.mb-1(for="year") Année
            input#year.w-full.border.border-gray-300.rounded-lg.px-3.py-2.text-sm.focus:outline-none.focus:ring-2.focus:ring-indigo-400(
              type="number"
              name="year"
              placeholder="2024"
              value=values && values.year
              min="1000"
              max="2099"
            )
          div
            label.block.text-sm.font-medium.text-gray-700.mb-1(for="genre") Genre
            input#genre.w-full.border.border-gray-300.rounded-lg.px-3.py-2.text-sm.focus:outline-none.focus:ring-2.focus:ring-indigo-400(
              type="text"
              name="genre"
              placeholder="Ex: Informatique"
              value=values && values.genre
            )

        .flex.gap-3
          button.flex-1.bg-indigo-600.hover:bg-indigo-700.text-white.font-semibold.py-2.rounded-lg.transition(type="submit")
            | Ajouter le livre
          a(href="/books").flex-1.text-center.border.border-gray-300.text-gray-600.hover:bg-gray-50.font-medium.py-2.rounded-lg.transition
            | Annuler
